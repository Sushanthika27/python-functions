def factors(n):
    f=[]
    for i in range(1,n+1):
       if n%i==0:
        f.append(i)
       return f
def is_prime(num):
   if num<2:
    return False
   for i in range(2,num):
      if num%i==0:
       return False
      return True
def prime_factors(n):
   pf=[]
   for i in range(1,n+1):
      if n%i==0 and is_prime(i):
       pf.append(i)
      return pf


