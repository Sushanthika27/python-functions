items = (
      ("Pen", 10, 10),
      ("Book", 100, 5),
      ("Bag", 500, 2)
      )
total = 0
for i in items:
   subtotal = i[1] * i[2]
   print(i[0], "subtotal =", subtotal)
   total = total + subtotal
